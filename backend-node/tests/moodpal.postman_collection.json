                  "})\r",
                  "\r",
                  "const response = pm.response.json();\r",
                  "const retdata = response.data;\r",
                  "pm.test(\"Success is returned\",()=>{\r",
                  "    pm.expect(response.success).to.eql(true)\r",
                  "})\r",
                  "const expectedEmail = pm.variables.get(\"email\");\r",
                  "const expectedID = pm.variables.get(\"userid\");\r",
                  "\r",
                  "pm.test(\"User list should contain exactly one matching user\", () => {\r",
                  "    pm.expect(response.data).to.be.an('array', 'Response data should be an array');\r",
                  "    pm.expect(response.data.length).to.eql(1, 'Expected exactly one user in the array');\r",
                  "    const user = response.data[0];\r",
                  "    pm.expect(user).to.have.property('email');\r",
                  "    pm.expect(user.email).to.eql(expectedEmail);\r",
                  "    pm.expect(user).to.have.property('_id');\r",
                  "    pm.expect(String(user._id)).to.eql(String(expectedID));\r",
                  "});"
